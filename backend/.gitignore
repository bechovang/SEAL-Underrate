# SEAL Underrate - Backend .gitignore

# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# =============================================================================
# Virtual Environments
# =============================================================================

venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# =============================================================================
# Environment Variables
# =============================================================================

.env
.env.local
.env.*.local

# KEEP .env.example for reference
!env.example

# =============================================================================
# Database
# =============================================================================

*.db
*.sqlite3
*.sqlite

# =============================================================================
# Logs
# =============================================================================

*.log
uvicorn.log
gunicorn.log

# =============================================================================
# Jupyter / IPython
# =============================================================================

.ipynb_checkpoints
profile_default/
ipython_config.py

# =============================================================================
# Playwright
# =============================================================================

playwright-report/
test-results/
playwright/.cache/

# =============================================================================
# IDEs & Editors
# =============================================================================

.vscode/
.idea/
*.code-workspace
*.iml

# =============================================================================
# OS Generated Files
# =============================================================================

.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Test & Temporary Files
# =============================================================================

test_*.py
*_test.py
*.tmp
*.temp
test_db.py
