# SEAL Underrate - Root .gitignore

# =============================================================================
# Python / Backend
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# C extensions
*.pyd

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Environment variables (KEEP .env.example)
.env
.env.local
.env.*.local

# Jupyter / IPython
.ipynb_checkpoints
profile_default/
ipython_config.py

# Logs
*.log
uvicorn.log

# Database
*.db
*.sqlite3
*.sqlite

# Playwright
playwright-report/
test-results/

# =============================================================================
# Node.js / Frontend
# =============================================================================

# Dependencies
node_modules/
jspm_packages/

# Next.js
.next/
out/
build/
dist/

# Production
*.tsbuildinfo
next-env.d.ts

# Debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*

# Local env files
.env
.env*.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript
*.tsbuildinfo

# =============================================================================
# IDEs & Editors
# =============================================================================

# VSCode
.vscode/
*.code-workspace

# JetBrains (IntelliJ, PyCharm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
[._]s[a-rt-v][a-z]
[._]ss[a-gi-z]
[._]sw[a-p]
Session.vim
Sessionx.vim
.netrwhist

# Emacs
*~
\#*\#
.\#*
TAGS
tags

# =============================================================================
# OS Generated Files
# =============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-0*
.nfs*

# =============================================================================
# Project Specific
# =============================================================================

# Claude Code memory
.claude/memory/

# BMad output
_bmad-output/

# Test files
test_*.py
*_test.py

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Screenshot cache
*.png
*.jpg
*.jpeg
!docs/assets/*.png
!docs/assets/*.jpg
!public/assets/*.png
!public/assets/*.jpg

# =============================================================================
# Security (DO NOT COMMIT)
# =============================================================================

# API Keys and Secrets
*secret*
*credentials*
*.pem
*.key
*.cert
auth.json
.npmrc
.yarnrc
